# =============================================================================
# .Rbuildignore for ClinicoPath Package
# =============================================================================
^\.RProfile$
^\.Rproj$
^.*\.Rproj$
^\.Rproj\.user$
^\.Rhistory$
^\.RData$
^\.Ruserdata$
^_pkgdown\.yml$
^\.github/
^docs/
^pkgdown/
^public/
^img/
^renv/
^renv\.lock$
^VIGNETTE_INTEGRATION_SUMMARY\.md$
^function_listing\.md$
^omv_test_data_listing\.md$
^jamovi/
^build/
^jamovi_modules/
^tr/
^quality-reports/
^temp/
^temp-books/
^delete/
^_tododata/
^tododata/
^_others/
^others/
^pdfs/
^data-raw/
^datageneration/
^tests/
^meddecide/
^ClinicoPathDescriptives/
^ClinicoPathLinuxDescriptives/
^jsurvival/
^jbbplot/
^jjstatsplot/
^ClinicoPath\.code-workspace$
^ClinicoPathJamoviModule\.code-workspace$
^DESCRIPTION-old\.txt$
^Rplots\.pdf$
^doc/
^Meta/
^temp$
^temp2$
^temp3$
^test_backups/
^temp-books/

# Ignore non-RDA data files in data directory
^data/.*\.csv$
^data/.*\.xlsx$
^data/.*\.omv$
^data/.*\.rds$
^data/.*\.RDS$
^data/.*\.RData$
^data/.*\.png$
^data/.*\.md$
^data/.*\.txt$
^data/.*\.jasp$
^data/.*\.xls$
^data/.*\.gif$
^data/.*\.mp4$
^data/.*\.R$

# Other exclusions
^.*Class\.Rd$
^_updateModules.*\.R$
^updateModules_config\.yaml$
^module-updates.*\.R$
^oncology_response_data\.R$
^create_test_data\.R$
^preparations-1\.R$
^quarto\.R$
^test_.*\.R$
^\.travis\.yml$
^codecov\.yml$
^\.gitlab-ci\.yml$
^tic\.R$
^\.circleci/
^appveyor\.yml$
^codemeta\.json$
^\.gitpod.*$
^\.binder/
^\.ccache/
^\.venv/
^clang-.*$
^gfortran.*$
^.*\.sh$
^.*\.Rd2pdf.*$
^chisq\.multcomp\.$
^modellingSurvival\.$
^R/for-utils\.R$
^R/utils-pipe\.R$
^R/diagnostic_metrics\.R$
^R/for_jjstatsplot\.R$
^CLAUDE.md
^AGENTS.md
^GEMINI.md
^TODO.md
^_updateModules.R
^updateModules_config.yaml
^module-updates.R
^\.claude$
^\.claude_prompts$
^\.tmp$
^CLAUDE\.md$
^CITATION\.cff$

# =============================================================================
# Non-standard top-level markdown/summary files
# =============================================================================
^COMPILATION_SUCCESS_REPORT\.md$
^COMPREHENSIVE_REVIEW_FIXES_SUMMARY\.md$
^CONTRIBUTING\.md$
^DATA_ORGANIZATION\.md$
^FIXES_APPLIED_SUMMARY\.md$
^IMPLEMENTATION_SUMMARY\.md$
^TESTING_GUIDE\.md$
^UI_REORGANIZATION_SUMMARY\.md$
^VALIDATION_CHECKLIST\.md$
^README_NEW_FEATURES\.md$
^README\.Rmd$
^LICENSE\.md$

# GROOMECOMPARE_* markdown files
^GROOMECOMPARE_.*\.md$

# RPASURVIVAL_* markdown files
^RPASURVIVAL_.*\.md$

# STAGEMIGRATION_* markdown files
^STAGEMIGRATION_.*\.md$

# enhancedROC_* markdown files
^enhancedROC_.*\.md$

# Other review/report markdown files
^psychopdaROC_team_review\.md$
^stagemigration_function_check_report\.md$
^TEST_DATA_.*\.md$

# =============================================================================
# Non-standard top-level R scripts (dev/debug/fix/utility)
# =============================================================================
^INSTALL_FMSB\.R$
^add_targeted_wrappers\.R$
^clean_untracked\.R$
^debug_.*\.R$
^fix_.*\.R$
^patch_add_items\.R$
^remove_.*\.R$
^update_tests\.R$
^test_groomecompare_.*\.R$

# =============================================================================
# Non-standard config/data files
# =============================================================================
^_updateModules_config\.yaml$
^_updateModules_utils\.R$
^groomecompare_test_data\.omv$
^generate_function_list\.py$
^PATCHES$
^ClinicoPath_.*\.tar\.gz$

# =============================================================================
# Log and text output files
# =============================================================================
^args_output\.txt$
^build_log\.txt$
^classical_failure\.log$
^comp_output\.txt$
^doc_log\.txt$
^edge_output\.txt$
^log\.txt$
^psychopda_basic_log\.txt$
^test_output.*\.txt$

# =============================================================================
# Development directories
# =============================================================================
^development-LLM/
^development-diagrams/
^development-documentations-dev\.jamovi\.org-master/
^development-ideas/
^development-scripts/
^i18n/
^i18n-plans/
^legacy/
^literature/
^tutorials/
^scripts/
^_snaps/
^image/

# Vignettes support files
^vignettes/developer_guide_files/
^vignettes/\.quarto/
^vignettes/_quarto\.yaml$
^vignettes/README\.md$
^vignettes/README_GUIDES\.md$
^vignettes/function_list\.md$
^vignettes/social-media-shares\.md$
^vignettes/rpa-survival-staging-workflow\.md$
^vignettes/.*_guide\.md$
